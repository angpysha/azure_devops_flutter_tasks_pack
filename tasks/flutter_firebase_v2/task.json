{
    "$schema": "https://raw.githubusercontent.com/Microsoft/azure-pipelines-task-lib/master/tasks.schema.json",
    "id": "b4e9c1d2-8a3f-4e5b-9c7d-1a2b3c4d5e6f",
    "name": "flutter-firebase-v2",
    "friendlyName": "Upload Flutter app to Firebase V2",
    "description": "Upload Flutter app to Firebase distribution using a GCP service account service connection",
    "helpMarkDown": "",
    "category": "Utility",
    "author": "Andrii Petrovskyi",
    "version": {
        "Major": 0,
        "Minor": 1,
        "Patch": 0
    },
    "instanceNameFormat": "Upload Flutter app to Firebase V2",
    "inputs": [
        {
            "name" : "type",
            "type": "pickList",
            "label": "Type",
            "defaultValue": "distribute",
            "required": true,
            "helpMarkDown": "Type of firebase util",
            "options": {
                "distribute": "Distribute",
                "uploadIOSSymbols": "Upload iOS symbols",
                "uploadFlutterDebugInfo": "Upload Flutter debug info",
                "custom": "Custom"
            }
        },
        {
            "name": "path",
            "type": "filePath",
            "label": "Path to binary to upload",
            "required": true,
            "helpMarkDown": "Path to the project folder",
            "visibleRule": "type = distribute"
        },
        {
            "name": "appId",
            "type": "string",
            "label": "App ID",
            "required": true,
            "helpMarkDown": "App ID",
            "visibleRule": "type = distribute"
        },
        {
            "name": "releaseNotes",
            "type": "filePath",
            "label": "Release notes",
            "required": false,
            "helpMarkDown": "Release notes",
            "visibleRule": "type = distribute"
        },
        {
            "name": "groups",
            "type": "multiLine",
            "label": "Groups",
            "required": true,
            "helpMarkDown": "Groups",
            "visibleRule": "type = distribute"
        },
        {
            "name": "customArgs",
            "type": "multiLine",
            "label": "Custom arguments",
            "required": true,
            "helpMarkDown": "Custom arguments",
            "visibleRule": "type = other"
        },
        {
            "name": "firebaseServiceConnection",
            "type": "connectedService:flutter-firebase-gcp-sa",
            "label": "GCP service account (service connection)",
            "required": true,
            "visibleRule": "type = distribute || type = custom",
            "helpMarkDown": "Service connection storing the full Google Cloud service account JSON key (same content as the secure file in the V1 task)."
        },
        {
            "name": "nointeractive",
            "type": "boolean",
            "label": "No interactive",
            "required": false,
            "helpMarkDown": "No interactive",
            "defaultValue": "true"
        },
        {
            "name": "uploaderPath",
            "type": "filePath",
            "label": "Path to firebase distribution uploader",
            "required": true,
            "visibleRule": "type = uploadIOSSymbols"
        },
        {
            "name": "symbolsPath",
            "type": "filePath",
            "label": "Path to symbols",
            "required": true,
            "visibleRule": "type = uploadIOSSymbols"
        },
        {
            "name": "googleServicesJson",
            "type": "secureFile",
            "label": "Path to Google services json",
            "required": true,
            "visibleRule": "type = uploadIOSSymbols"
        },
        {
            "name": "debugInfoPath",
            "type": "filePath",
            "label": "Path to directory with debug info",
            "required": true,
            "visibleRule": "type = uploadFlutterDebugInfo"
        },
        {
            "name": "firebaseAppId",
            "type": "string",
            "label": "Id of the Firebase app",
            "required": true,
            "visibleRule": "type = uploadFlutterDebugInfo"
        }

    ],
    "execution": {
        "Node20_1": {
            "target": "index.js"
        }
    }
}
